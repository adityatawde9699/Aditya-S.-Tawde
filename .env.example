# ─────────────────────────────────────────────────────────────────────────────
# Portfolio Backend Configuration Example
# Copy this file to server/.env and fill in the values
# ─────────────────────────────────────────────────────────────────────────────

# Server
NODE_ENV=development
PORT=8000

# Database — Neon Postgres connection string (serverless HTTP driver)
# Example: postgres://USER:PASSWORD@HOST/NAME?sslmode=require
DATABASE_URL=postgres://user:password@host/dbname?sslmode=require

# Auth / CMS (admin login at /admin)
JWT_SECRET=change-me-to-a-long-random-string
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me

# CORS — the URL of your production frontend
PROD_CLIENT_URL=https://your-frontend.vercel.app

# Email Settings (Required for Contact Form)
# For Gmail: use an "App Password", not your real password.
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
RECIPIENT_EMAIL=your-recipient-email@example.com

# Read-endpoint cache TTL in seconds (optional, default 3600)
# CACHE_TTL_SECONDS=3600
