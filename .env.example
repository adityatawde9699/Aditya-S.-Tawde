# ─────────────────────────────────────────────────────────────────────────────
# Portfolio Backend Configuration Example
# Copy this file to .env and fill in the values
# ─────────────────────────────────────────────────────────────────────────────

# Django Core Settings
DEBUG=True
SECRET_KEY=your-secret-key-run-python-command-to-generate
ALLOWED_HOSTS=localhost,127.0.0.1,.onrender.com

# Database Configuration
# Local: Leave unset to use SQLite automáticamente.
# Production: Set to your PostgreSQL connection string (psycopg2-binary required)
# Example: postgres://USER:PASSWORD@HOST:PORT/NAME
DATABASE_URL=postgres://user:password@localhost:5432/portfolio

# CORS & Frontend Integration
# The URL of your production frontend (e.g. https://your-portfolio.onrender.com)
PROD_CLIENT_URL=https://your-frontend.onrender.com

# Email Settings (Required for Contact Form)
# For Gmail: Use an "App Password", not your real password.
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
RECIPIENT_EMAIL=your-recipient-email@example.com

# WhiteNoise / Static Files (Optional override)
# STATIC_ROOT=staticfiles
