# Django Settings
DEBUG=True
SECRET_KEY=your-secret-key-change-in-production
ALLOWED_HOSTS=localhost,127.0.0.1,backend

# Database
# Local development: leave unset to use SQLite automatically.
# Production (required): set to a PostgreSQL connection string.
# Format: postgres://USER:PASSWORD@HOST:PORT/NAME
DATABASE_URL=postgres://postgres:postgres@db:5432/portfolio_db

# Email (required for contact form email notifications)
EMAIL_HOST_USER=your-gmail@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
RECIPIENT_EMAIL=your-email@example.com

# Production Frontend URL (for CORS)
PROD_CLIENT_URL=https://your-frontend.onrender.com

