# ─── Portfolio Frontend Environment (Vite) ───────────────────────────────
# Copy to .env in this directory

# API Base URL - The backend endpoint the frontend will communicate with.
# For local development, this usually points to your Hono server (e.g., http://127.0.0.1:8000/api)
# For production, this should be the full URL of your deployed backend.
VITE_API_URL=http://127.0.0.1:8000/api

# ─── Social Links (Optional Overrides) ───────────────────────────────────
# Leave blank or remove to use defaults hardcoded in config/social.js
VITE_SOCIAL_LINKEDIN=https://www.linkedin.com/in/aditya-s-tawde-7a1392315
VITE_SOCIAL_GITHUB=https://github.com/adityatawde9699
VITE_SOCIAL_INSTAGRAM=https://www.instagram.com/adityasuniltawde
VITE_SOCIAL_TWITTER=
# VITE_SOCIAL_TWITTER=https://x.com/your_handle

# ─── Contact ─────────────────────────────────────────────────────────────
VITE_CONTACT_EMAIL=adityatawde9699@gmail.com
VITE_GITHUB_USERNAME=adityatawde9699

# Note: All variables must be prefixed with VITE_ to be accessible in the client code.
# Access them via import.meta.env.VITE_VARIABLE_NAME
