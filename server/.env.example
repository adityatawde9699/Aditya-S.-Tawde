# ─── Portfolio Backend Environment (Hono + Neon) ──────────────────────────
# Copy to .env in this directory

# Server
NODE_ENV=development
PORT=8000

# Database — Neon Postgres connection string (HTTP serverless driver)
DATABASE_URL=postgres://user:password@host/dbname?sslmode=require

# Auth / CMS (admin login at /admin)
JWT_SECRET=change-me-to-a-long-random-string
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me

# Email (Gmail SMTP) — used by the contact form
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
RECIPIENT_EMAIL=

# CORS — production frontend origin
PROD_CLIENT_URL=https://aditya-s-tawde.vercel.app

# Read-endpoint cache TTL in seconds (default 3600)
# CACHE_TTL_SECONDS=3600
